#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int left, right;
    char temp;

    // Input string
    printf("Enter code name: ");
    scanf("%s", str);   // for single word

    // Initialize pointers
    left = 0;
    right = strlen(str) - 1;

    // Reverse string
    while(left < right) {
        temp = str[left];
        str[left] = str[right];
        str[right] = temp;

        left++;
        right--;
    }

    // Output
    printf("Mirror format: %s\n", str);

    return 0;
}
