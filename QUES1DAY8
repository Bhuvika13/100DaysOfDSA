#include <stdio.h>

// Recursive function to compute a^b
long long power(int a, int b) {
    if(b == 0)
        return 1;           // base case
    else
        return a * power(a, b - 1);
}

int main() {
    int a, b;

    printf("Enter base (a): ");
    scanf("%d", &a);

    printf("Enter exponent (b): ");
    scanf("%d", &b);

    if(b < 0) {
        printf("Negative exponent not supported in this version.\n");
        return 0;
    }

    printf("%d^%d = %lld\n", a, b, power(a, b));

    return 0;
}
