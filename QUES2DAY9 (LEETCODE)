#include <stdio.h>
#include <string.h>

void reverseString(char* s, int n) {
    int left = 0, right = n - 1;
    char temp;

    while(left < right) {
        temp = s[left];
        s[left] = s[right];
        s[right] = temp;

        left++;
        right--;
    }
}

int main() {
    char s[100];

    printf("Enter string: ");
    scanf("%s", s);

    reverseString(s, strlen(s));

    printf("Reversed string: %s\n", s);

    return 0;
}
