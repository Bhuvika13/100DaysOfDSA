#include <stdio.h>

int main() {
    int a[100], b[100], merged[200];
    int n1, n2, i, j, k;

    // Input first log
    printf("Enter number of elements in first log: ");
    scanf("%d", &n1);

    printf("Enter %d sorted elements:\n", n1);
    for(i = 0; i < n1; i++) {
        scanf("%d", &a[i]);
    }

    // Input second log
    printf("Enter number of elements in second log: ");
    scanf("%d", &n2);

    printf("Enter %d sorted elements:\n", n2);
    for(j = 0; j < n2; j++) {
        scanf("%d", &b[j]);
    }

    // Merge process
    i = 0; j = 0; k = 0;

    while(i < n1 && j < n2) {
        if(a[i] < b[j]) {
            merged[k++] = a[i++];
        } else {
            merged[k++] = b[j++];
        }
    }

    // Copy remaining elements
    while(i < n1) {
        merged[k++] = a[i++];
    }

    while(j < n2) {
        merged[k++] = b[j++];
    }

    // Output merged log
    printf("Merged chronological log:\n");
    for(i = 0; i < k; i++) {
        printf("%d ", merged[i]);
    }

    return 0;
}
