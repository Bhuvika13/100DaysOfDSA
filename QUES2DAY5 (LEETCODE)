#include <stdio.h>

int main() {
    int nums1[100], nums2[100];
    int m, n, i, j, k;

    // Input m and n
    printf("Enter number of elements in nums1 (m): ");
    scanf("%d", &m);

    printf("Enter number of elements in nums2 (n): ");
    scanf("%d", &n);

    // Input nums1 (size = m + n)
    printf("Enter %d elements of nums1 (remaining will be 0):\n", m);
    for(i = 0; i < m; i++) {
        scanf("%d", &nums1[i]);
    }

    // Fill remaining with 0 (optional, just for clarity)
    for(i = m; i < m + n; i++) {
        nums1[i] = 0;
    }

    // Input nums2
    printf("Enter %d elements of nums2:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &nums2[i]);
    }

    // Initialize pointers
    i = m - 1;
    j = n - 1;
    k = m + n - 1;

    // Merge from end
    while(i >= 0 && j >= 0) {
        if(nums1[i] > nums2[j]) {
            nums1[k] = nums1[i];
            i--;
        } else {
            nums1[k] = nums2[j];
            j--;
        }
        k--;
    }

    // If nums2 still has elements
    while(j >= 0) {
        nums1[k] = nums2[j];
        j--;
        k--;
    }

    // Output result
    printf("Merged array:\n");
    for(i = 0; i < m + n; i++) {
        printf("%d ", nums1[i]);
    }

    return 0;
}
