#include <stdio.h>

int main() {
    int n, i;
    int arr[100];
    int sum = 0, total, missing;

    // Input n
    printf("Enter value of n: ");
    scanf("%d", &n);

    // Input n-1 elements
    printf("Enter %d elements:\n", n - 1);
    for(i = 0; i < n - 1; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
    }

    // Total sum from 1 to n
    total = n * (n + 1) / 2;

    // Missing element
    missing = total - sum;

    printf("Missing element = %d\n", missing);

    return 0;
}
