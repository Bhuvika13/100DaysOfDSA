#include <stdio.h>

int main() {
    int nums[100], n, i;
    int k = 0;   // position for next non-zero element

    // Input size
    printf("Enter number of elements: ");
    scanf("%d", &n);

    // Input array
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    // Move non-zero elements forward
    for(i = 0; i < n; i++) {
        if(nums[i] != 0) {
            nums[k] = nums[i];
            k++;
        }
    }

    // Fill remaining with zeros
    for(i = k; i < n; i++) {
        nums[i] = 0;
    }

    // Output result
    printf("Array after moving zeros:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", nums[i]);
    }

    return 0;
}
