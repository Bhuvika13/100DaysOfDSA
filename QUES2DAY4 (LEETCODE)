#include <stdio.h>

int main() {
    int nums[100], n, val, i;
    int k = 0;  // count of elements not equal to val

    // Input size
    printf("Enter number of elements: ");
    scanf("%d", &n);

    // Input array
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    // Input value to remove
    printf("Enter value to remove: ");
    scanf("%d", &val);

    // Remove occurrences in-place
    for(i = 0; i < n; i++) {
        if(nums[i] != val) {
            nums[k] = nums[i];
            k++;
        }
    }

    // Output result
    printf("Number of elements not equal to %d = %d\n", val, k);

    printf("Updated array:\n");
    for(i = 0; i < k; i++) {
        printf("%d ", nums[i]);
    }

    return 0;
}
